dist/
build/
*.egg-info/
# Vite 构建输出，由 CI/CD 生成，不进 Git
frontend-dist/

# ── Node.js ──────────────────────────────────────────────────
node_modules/

# ── Vite 缓存 ─────────────────────────────────────────────────
