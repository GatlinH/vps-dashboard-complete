# ── 敏感文件 ─────────────────────────────────────────────────
.env
*.key
*.pem
*.p12
backend/admin-allowlist.conf   # 管理后台 IP 白名单（含运维 IP，不入版本库）

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
venv/
.venv/
env/
pip-log.txt

# ── Docker volumes ───────────────────────────────────────────
mysql_data/
redis_data/

# ── 系统 / IDE ───────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── 日志 ─────────────────────────────────────────────────────
*.log
logs/

# ── 构建产物 ─────────────────────────────────────────────────
dist/
build/
*.egg-info/
frontend-dist/          # Vite 构建输出，由 CI/CD 生成，不进 Git

# ── Node.js ──────────────────────────────────────────────────
node_modules/

# ── Vite 缓存 ─────────────────────────────────────────────────
frontend-vite/.vite/    # Vite 本地缓存目录

# ── PWA 构建中间产物 ──────────────────────────────────────────
sw.mjs                  # vite-plugin-pwa injectManifest 模式的中间文件
