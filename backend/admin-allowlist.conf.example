# ── 管理后台 IP 白名单 (Admin route IP allowlist) ────────────────────────────
#
# 用法（Usage）：
#   1. cp backend/admin-allowlist.conf.example backend/admin-allowlist.conf
#   2. 将下方 allow 示例替换为真实办公 / 运维 IP 或 CIDR
#   3. 验证并热重载：
#        docker compose exec nginx nginx -t
#        docker compose exec nginx nginx -s reload
#
# 格式（Format）：
#   每行一条 allow <IP 或 CIDR>;
#   文件末尾必须保留 deny all; —— 不可删除
#
# 示例（Examples）：
#   allow 203.0.113.10/32;      # 办公室固定出口 IP
#   allow 198.51.100.0/24;      # 运维跳板机网段
#   allow 10.0.0.0/8;           # 内网 / VPN 出口网段
#   allow 127.0.0.1;            # 本机回环（仅用于本地调试）
#   allow ::1;                  # IPv6 本机回环
#
# ⚠️  注意事项：
#   - allow/deny 规则按顺序匹配，第一条命中即生效，勿将 deny all 置于 allow 之前。
#   - 若使用 LB / CDN，须先在 nginx.conf 中正确配置 set_real_ip_from /
#     real_ip_header，否则此处比对的是代理 IP 而非真实客户端 IP。
#   - 不要将此文件提交到版本库（backend/admin-allowlist.conf 已加入 .gitignore）。
#   - 紧急追加 IP：编辑本文件增加一行 allow <IP>; 后执行上方重载命令即可。
#
# ─────────────────────────────────────────────────────────────────────────────

# TODO: 取消下方注释并替换为真实 IP / CIDR
# allow 203.0.113.10/32;     # 办公室出口 IP（示例，请替换）
# allow 10.0.0.0/8;          # 内网 / VPN 出口（示例，请替换）

deny all;  # 默认拒绝所有未明确允许的来源（请勿删除此行）
