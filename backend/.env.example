# backend/.env.example
# ⚠️ 安全说明：
#   1) 复制为 .env 后再启动：cp .env.example .env
#   2) .env 绝对不能提交到 Git
#   3) 生产环境会校验关键弱默认值，不符合将拒绝启动
#   4) 可用以下命令生成随机密钥：python -c "import secrets; print(secrets.token_hex(32))"

# ================== 运行环境 ==================
FLASK_ENV=production
FLASK_DEBUG=0
DEBUG=0
APP_VERSION=dev-local

# ================== 应用安全 ==================
# [必须修改] Flask 会话密钥（>=32位）
SECRET_KEY=CHANGE_ME_USE_python_secrets_token_hex_32
# [必须修改] JWT 密钥（>=32位，且必须与 SECRET_KEY 不同）
JWT_SECRET_KEY=CHANGE_ME_USE_python_secrets_token_hex_32_different
# 兼容字段（部分脚本/旧版本可能读取 JWT_SECRET）
JWT_SECRET=CHANGE_ME_COMPAT_ONLY

# 管理员默认密码（建议生产显式设置强密码；若留空则首次启动自动生成随机强密码并输出到日志）
# 强度建议：>=12 位，包含大小写字母、数字、特殊字符
ADMIN_DEFAULT_PASSWORD=

# ================== 数据库（MySQL） ==================
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=vps_user
# [必须修改] 生产环境强密码
MYSQL_PASSWORD=CHANGE_ME_STRONG_MYSQL_PASSWORD
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT_PASSWORD
MYSQL_DB=vps_dashboard

# 可选：连接串兼容字段（便于外部工具/未来迁移；当前代码按 MYSQL_* 组装 SQLALCHEMY_DATABASE_URI）
# 示例：mysql+pymysql://vps_user:password@mysql:3306/vps_dashboard?charset=utf8mb4
DATABASE_URL=
DB_URL=

# ================== 缓存（Redis） ==================
REDIS_HOST=redis
REDIS_PORT=6379
# [必须修改] Redis 认证密码（生产环境强密码，>=16位）
# 生成示例：python -c "import secrets; print(secrets.token_hex(24))"
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
REDIS_DB=0
# 可选：连接串兼容字段（建议在反向代理/限流组件中保持可读）
# 示例：redis://:password@redis:6379/0
REDIS_URL=
# JWT 黑名单检查在 Redis 异常时的策略：1=放行(高可用，存在短时失效风险)；0=拒绝(更安全)
JWT_BLOCKLIST_FAIL_OPEN=1

# ================== CORS ==================
# 开发可保留 localhost；生产请替换为正式域名
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_MAX_AGE=3600

# ================== 业务功能 ==================
# Telegram（可选，不配置则告警推送不可用）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# [可选，生产建议配置] 用于对数据库中存储的 bot_token 进行对称加密（AES-GCM）。
# 留空则退化为明文存储（不推荐生产使用）。
# 生成示例：python -c "import secrets; print(secrets.token_hex(32))"
TELEGRAM_TOKEN_SECRET=

# 探针与地图缓存
PROBE_TIMEOUT_S=5
PROBE_CACHE_TTL=15
TILE_CACHE_TTL=86400

# [必须修改] 敏感字段加密密钥（>=32位）
MASTER_ENCRYPTION_KEY=CHANGE_ME_USE_python_secrets_token_hex_32

# ================== 安全头 / Cookie ==================
FORCE_HTTPS=1
SESSION_COOKIE_SECURE=1
HSTS_ENABLED=1
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=1
HSTS_PRELOAD=1

# ================== 日志与观测 ==================
LOG_LEVEL=INFO
LOG_FILE=/var/log/vps-dashboard/app.log
# 可选：Loki 推送地址
LOKI_URL=

# Sentry（可选；SENTRY_DSN 为空则禁用，建议生产开启）
SENTRY_DSN=
SENTRY_TRACES_RATE=0.1
SENTRY_PROFILES_RATE=0.1

# ================== 邮件（密码找回等） ==================
# SMTP_MODE=smtp|log，开发建议 log，生产建议 smtp
SMTP_MODE=log
SMTP_HOST=localhost
SMTP_PORT=465
SMTP_USE_TLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=VPS星图 <noreply@example.com>
# [必填，SMTP_MODE=smtp 时强制要求] 前端域名，用于拼接邮件中的验证/重置链接。
# 缺失或为 localhost 时，SMTP 模式下启动将拒绝（防止邮件携带无效链接）。
# 示例：https://panel.example.com
FRONTEND_URL=

# ================== 支付（预留，可选） ==================
# 当前后端尚未使用 Stripe SDK，以下为预留字段，便于未来接入
# 若你只使用一个字段，推荐统一使用 STRIPE_SECRET
STRIPE_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ================== 任务与并发 ==================
AUDIT_LOG_RETENTION_DAYS=90
# 注意：使用 APScheduler 时 workers 必须保持 1，使用 threads 提升并发
GUNICORN_WORKERS=1
GUNICORN_THREADS=4
APP_WORKER_ID=0

# 兼容字段（当前配置类不直接读取，可供脚本/外部工具使用）
JWT_ACCESS_TOKEN_EXPIRES=28800
JWT_REFRESH_TOKEN_EXPIRES=2592000
TRAFFIC_ALERT_COOLDOWN_S=3600
