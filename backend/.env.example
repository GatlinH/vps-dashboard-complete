# backend/.env.example - 改进版本

# ================== 基本配置 ==================
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=your-secret-key-change-in-production-32chars
DEBUG=0

# ================== MySQL 配置 ==================
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=vps_user
MYSQL_PASSWORD=your-mysql-password
MYSQL_DB=vps_dashboard

# ================== Redis 配置 ==================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ================== JWT 配置 ==================
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRES=28800  # 8 小时
JWT_REFRESH_TOKEN_EXPIRES=2592000  # 30 天

# ================== CORS 配置 ==================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://yourdomain.com

# ================== Telegram 配置 ==================
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ================== 探针配置 ==================
PROBE_TIMEOUT_S=5
PROBE_CACHE_TTL=15

# ================== 地图瓦片配置 ==================
TILE_CACHE_TTL=86400

# ================== 加密配置 ==================
MASTER_ENCRYPTION_KEY=your-master-encryption-key

# ================== 安全配置 ==================
FORCE_HTTPS=1
SESSION_COOKIE_SECURE=1
HSTS_MAX_AGE=31536000

# ================== 日志配置 ==================
LOG_LEVEL=INFO
LOG_FILE=/var/log/vps-dashboard/app.log
