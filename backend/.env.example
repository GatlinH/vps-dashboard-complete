# ─────────────────────────────────────────────────────────────
# VPS 星图 · 环境变量模板
# 复制为 .env 并填入实际值，.env 不要提交到 Git
# ─────────────────────────────────────────────────────────────

# Flask
FLASK_DEBUG=0
SECRET_KEY=请替换为32位以上随机字符串
JWT_SECRET_KEY=请替换为另一个随机字符串

# MySQL
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=vps_user
MYSQL_PASSWORD=强密码请修改
MYSQL_DB=vps_dashboard

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Telegram（可选）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 跨域（前端地址，多个用逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://你的域名.com

# 探针超时（秒）
PROBE_TIMEOUT_S=5
PROBE_CACHE_TTL=15

# 地图瓦片缓存（秒）
TILE_CACHE_TTL=86400
