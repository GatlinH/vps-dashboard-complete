# backend/.env.example
# ⚠️  安全说明：
#   1. 将此文件复制为 .env，并修改所有标记为 [必须修改] 的值。
#   2. .env 文件绝对不能提交到 Git（已在 .gitignore 中排除）。
#   3. 生产环境若检测到弱默认值，应用将拒绝启动（见 config.py）。
#   4. 密钥建议使用 `python -c "import secrets; print(secrets.token_hex(32))"` 生成。

# ================== 基本配置 ==================
FLASK_ENV=production
FLASK_DEBUG=0
DEBUG=0

# [必须修改] 至少 32 位随机字符串，用于 Flask 会话签名
SECRET_KEY=CHANGE_ME_USE_python_secrets_token_hex_32

# 管理员默认密码（留空则首次启动时自动生成随机强密码并打印到控制台）
# [必须修改] 首次部署后请立即通过管理后台修改密码，不得使用 admin123 等弱密码上线
ADMIN_DEFAULT_PASSWORD=

# ================== MySQL 配置 ==================
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=vps_user
# [必须修改] 使用强密码，建议 16 位以上混合字符
MYSQL_PASSWORD=CHANGE_ME_STRONG_MYSQL_PASSWORD
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT_PASSWORD
MYSQL_DB=vps_dashboard

# ================== Redis 配置 ==================
REDIS_HOST=redis
REDIS_PORT=6379
# [建议修改] 生产环境强烈建议设置 Redis 密码，防止同宿主机其他进程未授权访问。
# 设置后需同步修改 docker-compose.yml redis command 为：
#   redis-server --requirepass YOUR_REDIS_PASSWORD --maxmemory 512mb ...
# 建议使用：python -c "import secrets; print(secrets.token_hex(24))" 生成
REDIS_PASSWORD=
REDIS_DB=0

# ================== JWT 配置 ==================
# [必须修改] 至少 32 位随机字符串，与 SECRET_KEY 不同
JWT_SECRET_KEY=CHANGE_ME_USE_python_secrets_token_hex_32_different
JWT_ACCESS_TOKEN_EXPIRES=28800   # 8 小时（秒）
JWT_REFRESH_TOKEN_EXPIRES=2592000  # 30 天（秒）

# ================== CORS 配置 ==================
# [必须修改] 仅填入你的正式域名，多个用逗号分隔；不要保留 localhost
# 示例: CORS_ORIGINS=https://yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ================== Telegram 配置 ==================
# 可选；不配置则告警推送功能不可用
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ================== 探针配置 ==================
PROBE_TIMEOUT_S=5
PROBE_CACHE_TTL=15

# ================== 地图瓦片配置 ==================
TILE_CACHE_TTL=86400

# ================== 加密配置 ==================
# [必须修改] 用于加密存储敏感数据
MASTER_ENCRYPTION_KEY=CHANGE_ME_USE_python_secrets_token_hex_32

# ================== 安全配置 ==================
FORCE_HTTPS=1
SESSION_COOKIE_SECURE=1
HSTS_MAX_AGE=31536000

# ================== 日志配置 ==================
LOG_LEVEL=INFO
LOG_FILE=/var/log/vps-dashboard/app.log

# ================== 审计日志配置 ==================
# 审计日志保留天数，超过此天数的记录将在每周日凌晨 3 点自动清理
AUDIT_LOG_RETENTION_DAYS=90

# ================== Gunicorn 并发配置 ==================
# 注意：因使用 APScheduler，Workers 必须保持为 1，用 Threads 提升并发
GUNICORN_WORKERS=1
GUNICORN_THREADS=4
